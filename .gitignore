# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.js
.pnpm-store

# testing
/packages/**/coverage
/.*coverage
.nyc_output

# report
/report.json
/packages/**/report.json

# production
/packages/**/build
/packages/**/lib

# Panda CSS — generated at build time, do not commit
/packages/**/styled-system
/packages/**/dist

# logs
logs
*.log*

# misc
cache
.*cache
.DS_Store
*.env
.idea/
*.pem
.history
fly.toml
dump.rdb
.*tmp

# Claude local files
.claude/
docs/superpowers/
CLAUDE.md

# connectors
/packages/core/connectors

# console auto generated files
/packages/console/src/consts/jwt-customizer-type-definition.ts
packages/connectors/connector-whatsapp/test-send.mjs

# Turborepo
.turbo

# Local scratch archive: files moved here by the destructive-command hook (instead of
# rm/stash). Keep untracked dumps out of git; already-tracked archive entries (README,
# the Inkeep/OssCloud files) stay tracked since gitignore doesn't affect tracked files.
/archive/
