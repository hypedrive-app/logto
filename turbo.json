{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.json", "tsconfig.base.json", ".env"],
  "tasks": {
    "generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["lib/**", "build/**", "dist/**", "src/generated-types/**"]
    },
    "build:test": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["lib/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "stylelint": {},
    "test:ci": {
      "dependsOn": ["^build", "build:test"],
      "outputs": ["coverage/**"]
    }
  }
}
